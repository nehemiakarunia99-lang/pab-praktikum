package com.nehem.pabweek3.data

import android.content.Context
import androidx.datastore.preferences.core.edit
import androidx.datastore.preferences.core.stringPreferencesKey
import androidx.datastore.preferences.preferencesDataStore
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.map
import kotlinx.serialization.encodeToString
import kotlinx.serialization.json.Json

// Ekstensi Context untuk membuat instance DataStore (singleton by delegate)
val Context.todoDataStore by preferencesDataStore(name = "todo_prefs")

/**
 * Repository untuk menyimpan & membaca daftar todo menggunakan DataStore.
 *
 * Alasan pakai DataStore (bukan SharedPreferences/File Storage):
 * 1. Data todo berupa List<TodoItem> yang terstruktur -> diserialisasi ke JSON,
 *    lalu disimpan sebagai satu String di DataStore.
 * 2. DataStore berbasis Coroutines & Flow, sehingga proses baca/tulis
 *    berjalan asynchronous dan tidak memblokir main thread (UI tetap responsif),
 *    berbeda dengan SharedPreferences yang operasinya synchronous.
 * 3. Data otomatis reactive: setiap perubahan langsung ter-emit lewat Flow,
 *    cocok dipakai bersama Compose state (collectAsState).
 * 4. File Storage lebih cocok untuk data besar/biner (gambar, dokumen),
 *    sedangkan data todo ini kecil dan terstruktur, jadi DataStore lebih pas.
 */
class TodoRepository(private val context: Context) {

    private val TODO_LIST_KEY = stringPreferencesKey("todo_list")
    private val json = Json { ignoreUnknownKeys = true }

    // Membaca daftar todo sebagai Flow (reactive, auto-update kalau data berubah)
    val todosFlow: Flow<List<TodoItem>> = context.todoDataStore.data.map { prefs ->
        val jsonString = prefs[TODO_LIST_KEY] ?: return@map emptyList()
        try {
            json.decodeFromString<List<TodoItem>>(jsonString)
        } catch (e: Exception) {
            emptyList()
        }
    }

    // Menyimpan seluruh daftar todo ke DataStore (dipanggil tiap ada perubahan)
    suspend fun saveTodos(todos: List<TodoItem>) {
        val jsonString = json.encodeToString(todos)
        context.todoDataStore.edit { prefs ->
            prefs[TODO_LIST_KEY] = jsonString
        }
    }
}